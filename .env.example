# ─────────────────────────────────────────────
# CONFIGURACIÓN DE GMAIL
# ─────────────────────────────────────────────

# Nombre del label de Gmail del que se leerán los correos
GMAIL_LABEL=noticias

# Dirección de correo de la cuenta de Gmail autorizada
GMAIL_USER=tu_correo@gmail.com

# Destinatario del resumen (puede ser el mismo GMAIL_USER)
DIGEST_RECIPIENT=tu_correo@gmail.com

# ─────────────────────────────────────────────
# CONFIGURACIÓN DE CLAUDE (Anthropic)
# ─────────────────────────────────────────────

# Clave de API de Anthropic (formato: sk-ant-api03-...)
ANTHROPIC_API_KEY=sk-ant-api03-...

# ─────────────────────────────────────────────
# CONFIGURACIÓN DEL SCHEDULER
# ─────────────────────────────────────────────

# Expresión cron para el horario de ejecución
# Por defecto: lunes a viernes a las 7:00 AM (hora Argentina)
CRON_SCHEDULE="0 7 * * 1-5"

# Zona horaria para el cron (usar nombres IANA, ej: America/Buenos_Aires)
CRON_TIMEZONE=America/Buenos_Aires

# ─────────────────────────────────────────────
# LÍMITES DE PROCESAMIENTO
# ─────────────────────────────────────────────

# Máximo de emails a procesar por ejecución
MAX_EMAILS_PER_RUN=30

# Solo procesar emails de las últimas N horas
HOURS_LOOKBACK=24

# ─────────────────────────────────────────────
# CONFIGURACIÓN SMTP (envío del resumen)
# ─────────────────────────────────────────────

# Servidor SMTP (para Gmail usar smtp.gmail.com)
SMTP_HOST=smtp.gmail.com

# Puerto SMTP: 587 para STARTTLS (recomendado), 465 para SSL implícito
SMTP_PORT=587

# Usuario SMTP (tu dirección de Gmail)
SMTP_USER=tu_correo@gmail.com

# Contraseña de aplicación de Gmail (16 caracteres, NO la contraseña real)
# Generarla en: Cuenta de Google → Seguridad → Contraseñas de aplicación
SMTP_PASS=xxxx xxxx xxxx xxxx
